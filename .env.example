# Clerk (Dashboard > API keys). Auth is handled by Clerk.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Route Clerk's sign-in UI to our page; land on the journal after auth.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Supabase Postgres — transaction pooler (port 6543). Used by Drizzle for all
# app queries. (Supabase is now just the database; auth is Clerk.)
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:PASSWORD@aws-0-xx-xxxx-1.pooler.supabase.com:6543/postgres

# Session pooler (port 5432) — used only by `npm run db:migrate`.
MIGRATE_DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:PASSWORD@aws-0-xx-xxxx-1.pooler.supabase.com:5432/postgres

# Google Cloud service account JSON (single line), scoped to Sheets API only,
# shared with the target spreadsheet as an editor. Server-only. Optional —
# only needed for the sheet export.
GOOGLE_SERVICE_ACCOUNT_KEY={"client_email":"...","private_key":"..."}

# Shared secret the GitHub Actions cron sends as `Authorization: Bearer
# <value>` to POST /api/export/drain. Generate with: openssl rand -hex 32
CRON_SECRET=
