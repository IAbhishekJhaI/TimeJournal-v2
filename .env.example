# Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL= 
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the browser, never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase project settings > Database > Connection string > Transaction
# pooler (port 6543). Used by Drizzle for all app queries.
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:PASSWORD@aws-0-xx-xxxx-1.pooler.supabase.com:6543/postgres

# Google Cloud service account JSON (single line), scoped to Sheets API
# only, shared with the target spreadsheet as an editor. Used server-side
# only by the export worker — never sent to the browser.
GOOGLE_SERVICE_ACCOUNT_KEY={"client_email":"...","private_key":"..."}

# Shared secret the GitHub Actions cron sends as `Authorization: Bearer
# <value>` to POST /api/export/drain. Generate with: openssl rand -hex 32
CRON_SECRET=

